{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "Node16",
    "moduleResolution": "Node16",
    "rootDir": "src",
    "outDir": "out/cli",
    "noEmit": false,
    "declaration": true,
    "sourceMap": true,
    "lib": ["ES2022"],
    "types": ["node"]
  },
  "include": ["src/cli/**/*.ts", "src/sync/**/*.ts"]
}
